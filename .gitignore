# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# IDE and editors
.idea/
.vscode/

# Dependencies
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# Production builds
/build
dist/
dist

# Environment files (comprehensive coverage)

*token.json*
*credentials.json*

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# System files
.DS_Store
*.pem

# Python
__pycache__/
*pyc*
venv/
.venv/

# Development tools
chainlit.md
.chainlit
.ipynb_checkpoints/
.ac

# Deployment
.vercel

# Data and databases
agenthub/agents/youtube/db

# Archive files and large assets
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Build caches
.cache/

memory/test_credentials.md

# Mobile development
android-sdk/
# UltraLite — TRUE secrets only (keystore/passwords).
# google-services.json is intentionally NOT ignored — Google states it's safe
# to commit (it has no secret keys, only client IDs that are visible in the
# compiled APK anyway). The workflow falls back to a GitHub Secret if absent.
*.keystore
*.jks
upload.keystore
release.keystore
.env.local
.env.*.local

# Native build artefacts (regenerated by expo prebuild on every CI run)
frontend/android/
frontend/ios/
-e 
